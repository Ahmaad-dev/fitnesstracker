# ===== FitTracker – Umgebungsvariablen =====
# Kopiere diese Datei zu app.env und fülle die Werte aus.
# app.env wird NICHT in Git committet.

# Flask Session-Secret (beliebiger zufälliger String, mind. 32 Zeichen)
# Erzeugen: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=DEIN_ZUFAELLIGER_SECRET_KEY

# Login-Passwort als bcrypt-Hash.
# Erzeugen:
#   docker run --rm python:3.12-slim python -c "import bcrypt; print(bcrypt.hashpw(b'DEIN_PASSWORT', bcrypt.gensalt()).decode())"
# Wichtig: $$ verdoppeln wegen Docker-Compose-Interpolation
APP_PASSWORD_HASH=$$2b$$12$$DEIN_BCRYPT_HASH

# Garmin Connect Zugangsdaten (leer lassen → Garmin-Sync deaktiviert)
GARMIN_EMAIL=deine@email.com
GARMIN_PASSWORD=DEIN_GARMIN_PASSWORT
GARMIN_TOKEN_DIR=/data/garmin_tokens

# Datum ab dem Garmin-Aktivitäten importiert werden (Format: YYYY-MM-DD)
GARMIN_SYNC_FROM_DATE=2026-01-01

# OpenAI API-Key (leer lassen → KI-Empfehlung deaktiviert)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Datenbank (Standard: SQLite in /data, kein Änderungsbedarf)
DATABASE_URL=sqlite:////data/fitness.db
DATA_DIR=/data
